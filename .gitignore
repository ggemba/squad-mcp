node_modules/
dist/
*.log
.env
.env.local
.DS_Store
coverage/
.vscode/
.idea/

# squad-mcp internal snapshot backups — regenerated on every write by the
# file-lock safety path. Tracking them just spams the diff.
.squad/*.prev

# JSONL quarantine files from the learning store (corrupted-line side files)
.squad/*.corrupt-*.jsonl

# squad-mcp run journal — local-only operational telemetry (v0.9.0+).
# Remove these two lines if you want team-wide run sharing.
.squad/runs.jsonl
.squad/runs.jsonl.lock
.squad/.stats-seen

# squad-mcp task store — local task decomposition per /squad:tasks. The SKILL
# leaves trackable-or-not to each repo's discretion. For this repo (which IS
# the squad-mcp project) we don't want internal task snapshots shipping with
# releases — remove this line if your team wants to share decompositions.
.squad/tasks.json
.squad/tasks.json.prev

# squad-mcp auto-journaling staging buffer (PR1 / Fase 1a) — local-only
# transient breadcrumbs captured by the opt-in PostToolUse hook, plus its
# atomic-rename drain sidecars, quarantine side files, and the copied hook
# scripts. None of these are meant to ship with releases.
.squad/pending-journal.jsonl
.squad/pending-journal.jsonl.draining-*.jsonl
.squad/pending-journal.jsonl.corrupt-*.jsonl
.squad/hooks/

# personal exploration scripts (not for publish)
tools/inspect-warp-db.mjs
