# squad-mcp internal snapshot backups — regenerated on every write by the
# file-lock safety path. Tracking them just spams the diff.
.squad/*.prev

# JSONL quarantine files from the learning store (corrupted-line side files)
.squad/*.corrupt-*.jsonl

# squad-mcp run journal — local-only operational telemetry (v0.9.0+).
# Remove these two lines if you want team-wide run sharing.
.squad/runs.jsonl
.squad/runs.jsonl.lock
.squad/.stats-seen

