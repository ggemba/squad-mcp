{
  "name": "squad",
  "version": "1.2.0",
  "description": "Squad-dev workflow as a Claude Code plugin: classification, risk scoring, agent selection, advisory orchestration. Bundles an MCP server, native subagents, and the /squad:implement and /squad:review slash commands.",
  "license": "Apache-2.0",
  "author": {
    "name": "Gustavo",
    "email": "next.uh@gmail.com"
  },
  "homepage": "https://github.com/ggemba/squad-mcp#readme",
  "repository": "https://github.com/ggemba/squad-mcp",
  "keywords": ["mcp", "squad-dev", "code-review", "advisory", "agent"],
  "agents": [
    "./agents/product-owner.md",
    "./agents/tech-lead-planner.md",
    "./agents/tech-lead-consolidator.md",
    "./agents/architect.md",
    "./agents/dba.md",
    "./agents/developer.md",
    "./agents/reviewer.md",
    "./agents/security.md",
    "./agents/qa.md",
    "./agents/code-explorer.md",
    "./agents/debugger.md",
    "./agents/implementer.md"
  ],
  "commands": [
    "./commands/implement.md",
    "./commands/review.md",
    "./commands/tasks.md",
    "./commands/next.md",
    "./commands/task.md",
    "./commands/question.md",
    "./commands/brainstorm.md",
    "./commands/commit-suggest.md",
    "./commands/stats.md",
    "./commands/debug.md",
    "./commands/grillme.md",
    "./commands/enable-journaling.md",
    "./commands/pipeline.md"
  ],
  "skills": "./skills/",
  "mcpServers": {
    "squad": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/bin/launch.mjs"]
    }
  }
}
